# --- TickTick ---
TICKTICK_EMAIL=seu-email@exemplo.com
TICKTICK_PASSWORD=sua-senha-aqui
TICKTICK_USER_ID=120203111

# Opcional: cookie de sessao pre-capturado (pula login se preenchido)
TICKTICK_TOKEN=

# --- MCP server ---
# Token secreto que o Claude vai mandar no path da URL.
# Gere algo tipo: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_TOKEN=troque-por-um-token-longo-aleatorio

# Porta local (Fly.io injeta PORT automaticamente em produção)
PORT=8000
